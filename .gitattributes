# Default behaviour: normalise line endings to LF in the repo,
# and check out with LF line endings by default.
* text=auto eol=lf

# --- C# / .NET source ---
*.cs        text eol=lf diff=csharp
*.csx       text eol=lf diff=csharp
*.cake      text eol=lf diff=csharp

# --- Project / solution files ---
*.csproj    text eol=lf diff=xml
*.fsproj    text eol=lf diff=xml
*.vbproj    text eol=lf diff=xml
*.sln       text eol=lf merge=union
*.slnx      text eol=lf merge=union
*.props     text eol=lf diff=xml
*.targets   text eol=lf diff=xml
*.nuspec    text eol=lf diff=xml

# --- Configuration / data ---
*.json      text eol=lf
*.xml       text eol=lf diff=xml
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.config    text eol=lf diff=xml
*.runsettings text eol=lf diff=xml

# --- Shell / scripts ---
*.sh        text eol=lf
*.bash      text eol=lf
*.ps1       text eol=lf
*.psm1      text eol=lf
*.psd1      text eol=lf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# --- Docs / markdown ---
*.md        text eol=lf
*.txt       text eol=lf
*.rst       text eol=lf
LICENSE     text eol=lf
README      text eol=lf

# --- Web assets (if ever added) ---
*.html      text eol=lf diff=html
*.htm       text eol=lf diff=html
*.css       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.jsx       text eol=lf
*.tsx       text eol=lf

# --- Binary: images ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.webp      binary

# --- Binary: archives ---
*.zip       binary
*.tar       binary
*.gz        binary
*.tgz       binary
*.bz2       binary
*.7z        binary
*.rar       binary

# --- Binary: .NET / build outputs ---
*.dll       binary
*.exe       binary
*.pdb       binary
*.nupkg     binary
*.snupkg    binary

# --- Binary: SQLite databases ---
*.db        binary
*.sqlite    binary
*.sqlite3   binary

# --- Binary: fonts ---
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
